<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<fx:root type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         title="MyCelia" minWidth="600" minHeight="650" onCloseRequest="#handleExit">
  <icons>
    <Image url="@/images/address_book_32.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@DarkTheme.css" />
        <URL value="@Extensions.css" />
      </stylesheets>

      <VBox style="-fx-background-color: #0d1117;">

        <!-- Hidden MenuBar for keyboard accelerators (F1 help) -->
        <MenuBar fx:id="menuBar" visible="false" managed="false">
          <Menu mnemonicParsing="false" text="File">
            <MenuItem mnemonicParsing="false" onAction="#handleExit" text="Exit" />
          </Menu>
          <Menu mnemonicParsing="false" text="Help">
            <MenuItem fx:id="helpMenuItem" mnemonicParsing="false" onAction="#handleHelp" text="Help" />
          </Menu>
        </MenuBar>

        <!-- Top Bar: App Title + Pill Toggle + User Address -->
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
          <Label text="MyCelia" styleClass="app-title" />

          <!-- Pill Toggle -->
          <HBox fx:id="pillToggle" styleClass="pill-toggle" alignment="CENTER_LEFT">
            <Button fx:id="pillCompanies" text="Companies" styleClass="pill-button-active"
                    onAction="#handlePillCompanies" />
            <Button fx:id="pillDeliveries" text="Deliveries" styleClass="pill-button"
                    onAction="#handlePillDeliveries" />
            <Button fx:id="pillRoutes" text="Routes" styleClass="pill-button"
                    onAction="#handlePillRoutes" />
          </HBox>

          <!-- Spacer -->
          <Region HBox.hgrow="ALWAYS" />

          <!-- User Address (compact, right-aligned) -->
          <Label fx:id="userAddressLabel" styleClass="user-address-label" />
        </HBox>

        <!-- Command Box -->
        <StackPane VBox.vgrow="NEVER" fx:id="commandBoxPlaceholder" style="-fx-background-color: #0d1117;">
          <padding>
            <Insets top="8" right="16" bottom="4" left="16" />
          </padding>
        </StackPane>

        <!-- Result Display (compact feedback bar) -->
        <StackPane VBox.vgrow="NEVER" fx:id="resultDisplayPlaceholder" styleClass="feedback-bar"
                   minHeight="32" prefHeight="32" maxHeight="48">
          <padding>
            <Insets top="2" right="16" bottom="2" left="16" />
          </padding>
        </StackPane>

        <!-- Tab Pane (headers hidden, controlled by pill toggle) -->
        <TabPane fx:id="listTabPane" VBox.vgrow="ALWAYS">
          <tabs>
            <Tab closable="false" text="Companies">
              <VBox style="-fx-background-color: #0d1117;" minWidth="340" prefWidth="340">
                <padding>
                  <Insets top="10" right="12" bottom="10" left="12" />
                </padding>
                <StackPane fx:id="companyListPanelPlaceholder" VBox.vgrow="ALWAYS" />
              </VBox>
            </Tab>

            <Tab closable="false" text="Deliveries">
              <VBox style="-fx-background-color: #0d1117;" minWidth="340" prefWidth="340">
                <padding>
                  <Insets top="10" right="12" bottom="10" left="12" />
                </padding>
                <Button fx:id="mapSelectedDeliveriesButton"
                        text="Plan Today's Route"
                        onAction="#handleShowSelectedRoutes"
                        disable="true"
                        styleClass="button">
                  <VBox.margin>
                    <Insets bottom="8" />
                  </VBox.margin>
                </Button>
                <StackPane fx:id="deliveryListPanelPlaceholder" VBox.vgrow="ALWAYS" />
              </VBox>
            </Tab>

            <Tab closable="false" text="Routes">
              <StackPane fx:id="routePanelPlaceholder" style="-fx-background-color: #0d1117;" />
            </Tab>
          </tabs>
          <VBox.vgrow>
            <Priority fx:constant="ALWAYS" />
          </VBox.vgrow>
        </TabPane>

        <StackPane fx:id="statusbarPlaceholder" VBox.vgrow="NEVER" />
      </VBox>
    </Scene>
  </scene>
</fx:root>
