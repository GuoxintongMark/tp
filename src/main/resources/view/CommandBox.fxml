<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="command-area" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <!-- Row 1: prompt symbol + text field -->
  <HBox alignment="CENTER_LEFT">
    <Label fx:id="promptLabel" text="❯" styleClass="command-prompt" />
    <TextField fx:id="commandTextField" onAction="#handleCommandEntered"
               promptText="Type a command..."
               HBox.hgrow="ALWAYS" />
  </HBox>

  <!-- Row 2: ghost hint line -->
  <Label fx:id="hintLabel" styleClass="command-hint" text="" wrapText="false" />
</VBox>
